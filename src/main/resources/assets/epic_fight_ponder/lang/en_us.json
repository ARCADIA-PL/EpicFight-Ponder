{
  "epic_fight_ponder.ponder.tachi_rushing_tempo.header": "Tachi Innate Skill: Rushing Tempo",
  "epic_fight_ponder.ponder.tachi_rushing_tempo.text_1": "Rushing Tempo allows you to weave skill strikes into your basic attack recovery.",
  "epic_fight_ponder.ponder.tachi_rushing_tempo.text_2": "Press the skill key immediately during the attack recovery window!",
  "epic_fight_ponder.ponder.tachi_rushing_tempo.text_3": "Successful derivation! Keep the rhythm to chain attacks infinitely...",
  "epic_fight_ponder.ponder.tachi_rushing_tempo.text_4": "Can also be derived after dash or jump attacks.",

